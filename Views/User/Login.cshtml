@model MvcMyBad.Models.PostUserDto


@section Styles {
    <link rel="stylesheet" href="~/css/pages/signIn.css" asp-append-version="true" />
}

<div class="signin-container">
    <div class="form-section col-md-6">
        <h2> Connexion à MyBadminton</h2>
        <p>Vous n'avez pas de compte ? <a asp-controller="User" asp-action="Create">Inscrivez-vous</a></p>
        <form asp-route="LoginUser" method="post">

            <div class="form-group">
                <label asp-for="Pseudo" class="control-label"></label>
                <input asp-for="Pseudo" class="form-control" />
                <span asp-validation-for="Pseudo" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password" class="control-label"></label>
                <input asp-for="Password" type="password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="button">
                <input type="submit" value="Connexion" class="btn btn-primary" />
            </div>
        </form>
    </div>

    <div class="image-section col-md-6">
        <img src="https://images.unsplash.com/photo-1559309106-ed14040fd35d?q=80&w=2127&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
            class="img-fluid h-100 w-100 object-fit-cover" />
    </div>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}